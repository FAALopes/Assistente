{
  "name": "assistente-backend",
  "version": "1.0.0",
  "description": "Email control panel backend - Assistente",
  "main": "dist/index.js",
  "scripts": {
    "build": "npx prisma generate && tsc && cd client && npm install && npm run build",
    "start": "npx prisma migrate deploy && node dist/index.js",
    "dev": "concurrently \"tsc --watch\" \"node --watch dist/index.js\"",
    "prisma:migrate": "npx prisma migrate deploy",
    "prisma:generate": "npx prisma generate",
    "postinstall": "npx prisma generate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@azure/msal-node": "^2.16.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@prisma/client": "^6.4.1",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "isomorphic-fetch": "^3.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.1",
    "@types/node": "^22.13.5",
    "prisma": "^6.4.1",
    "typescript": "^5.7.3"
  }
}
